---
interface Props {
  lang: string;
  t: any;
}
const { t } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="px-6 py-6">
  <p class="max-w-lg mx-auto text-center text-xs text-stone-500 dark:text-slate-600">
    © {year} Olivio Subelza. {t.footer.rights} · {t.footer.built}
    <a href="https://astro.build" target="_blank" rel="noopener noreferrer"
       class="hover:text-[#0D9488] transition-colors">
      Astro
    </a>
  </p>
</footer>
