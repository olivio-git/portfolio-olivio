---

<div id="color-picker" style="position:fixed;bottom:24px;right:24px;z-index:9999;background:#1a1a1a;border:1px solid #333;border-radius:12px;padding:12px 14px;display:flex;flex-direction:column;gap:10px;box-shadow:0 8px 32px rgba(0,0,0,0.4);">
  <p style="font-size:10px;color:#666;margin:0;text-transform:uppercase;letter-spacing:.08em;">Accent color</p>
  <div style="display:flex;gap:8px;flex-wrap:wrap;max-width:180px;">
    <button data-color="#DA7756" title="Indigo"    style="width:24px;height:24px;border-radius:50%;background:#DA7756;border:2px solid transparent;cursor:pointer;"></button>
    <button data-color="#D97706" title="Amber"     style="width:24px;height:24px;border-radius:50%;background:#D97706;border:2px solid transparent;cursor:pointer;"></button>
    <button data-color="#0D9488" title="Teal"      style="width:24px;height:24px;border-radius:50%;background:#0D9488;border:2px solid transparent;cursor:pointer;"></button>
    <button data-color="#E05C3A" title="Coral"     style="width:24px;height:24px;border-radius:50%;background:#E05C3A;border:2px solid transparent;cursor:pointer;"></button>
    <button data-color="#059669" title="Emerald"   style="width:24px;height:24px;border-radius:50%;background:#059669;border:2px solid transparent;cursor:pointer;"></button>
    <button data-color="#E11D48" title="Rose"      style="width:24px;height:24px;border-radius:50%;background:#E11D48;border:2px solid transparent;cursor:pointer;"></button>
    <button data-color="#7C3AED" title="Violet"    style="width:24px;height:24px;border-radius:50%;background:#7C3AED;border:2px solid transparent;cursor:pointer;"></button>
    <button data-color="#DA7756" title="Guindo"    style="width:24px;height:24px;border-radius:50%;background:#DA7756;border:2px solid transparent;cursor:pointer;"></button>
  </div>
  <p id="color-label" style="font-size:11px;color:#aaa;margin:0;font-family:monospace;">#DA7756</p>
</div>

<script is:inline>
  (function () {
    // inject a <style> tag we'll update on each pick
    const style = document.createElement("style");
    document.head.appendChild(style);

    const label = document.getElementById("color-label");

    function lighten(hex) {
      // produce a slightly lighter shade for hover
      const r = parseInt(hex.slice(1,3),16);
      const g = parseInt(hex.slice(3,5),16);
      const b = parseInt(hex.slice(5,7),16);
      const amt = 40;
      return "#" + [r,g,b].map(c => Math.min(255,c+amt).toString(16).padStart(2,"0")).join("");
    }

    function applyColor(hex) {
      const hover = lighten(hex);
      // replace every occurrence of the accent color in the document
      style.textContent = `
        * { --accent: ${hex} !important; }
        [class*="text-[#"]:not([class*="slate"]):not([class*="emerald"]):not([class*="amber"]) { color: inherit; }
        .nav-link.active { color: ${hex} !important; }
        .nav-link::after { background-color: ${hex} !important; }
      `;

      // update inline colors by replacing CSS variables
      document.documentElement.style.setProperty("--cp-accent", hex);
      document.documentElement.style.setProperty("--cp-hover", hover);

      // patch every element that has the old accent color inlined or via Tailwind arbitrary
      document.querySelectorAll("[class]").forEach(el => {
        el.className = el.className
          .replace(/text-\[#[0-9a-fA-F]{6}\]/g, `text-[${hex}]`)
          .replace(/bg-\[#[0-9a-fA-F]{6}\]/g, `bg-[${hex}]`)
          .replace(/border-\[#[0-9a-fA-F]{6}\]/g, `border-[${hex}]`);
      });

      // Tailwind arbitrary values won't re-generate at runtime so force via style injection
      style.textContent = `
        .nav-link.active { color: ${hex} !important; }
        .nav-link.active::after { background-color: ${hex} !important; }
        .nav-link::after { background-color: ${hex} !important; }
        a:not([class*="slate"]):not([class*="white"]):not([class*="gray"]) [style*="color"] { color: ${hex}; }
        /* accent overrides */
        .accent-color { color: ${hex} !important; }
        .accent-bg { background-color: ${hex} !important; }
        .accent-border { border-color: ${hex} !important; }
      `;

      // Mark active swatch
      document.querySelectorAll("#color-picker button[data-color]").forEach(btn => {
        btn.style.border = btn.dataset.color.toLowerCase() === hex.toLowerCase()
          ? "2px solid white"
          : "2px solid transparent";
      });

      label.textContent = hex;
      localStorage.setItem("cp-accent", hex);
    }

    // Init from storage or default
    const saved = localStorage.getItem("cp-accent") || "#DA7756";
    applyColor(saved);

    document.querySelectorAll("#color-picker button[data-color]").forEach(btn => {
      btn.addEventListener("click", () => applyColor(btn.dataset.color));
    });
  })();
</script>
