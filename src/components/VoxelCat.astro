<!--
  Voxel version of the site's mascot: a sitting cat licking its raised paw
  (toe beans out, happy closed eyes) — built procedurally with three.js.
  Theme-reactive like the logo: cream cat in dark mode, black cat in light mode.
  Orthographic camera orbits slowly; drag to rotate. Idle life: breathing,
  tail sway, occasional ear twitch.
-->
<div
  id="voxel-cat"
  class="voxel-cat relative mx-auto -mb-2 h-[260px] w-full max-w-[520px] cursor-grab active:cursor-grabbing sm:h-[340px]"
  aria-hidden="true"
>
</div>

<style>
  .voxel-cat canvas {
    opacity: 0;
    transition: opacity 0.9s ease;
  }
  .voxel-cat.is-ready canvas {
    opacity: 1;
  }
</style>

<script>
  import * as THREE from "three";
  import { RoomEnvironment } from "three/examples/jsm/environments/RoomEnvironment.js";
  import { mergeGeometries } from "three/examples/jsm/utils/BufferGeometryUtils.js";
  import { OrbitControls } from "three/examples/jsm/controls/OrbitControls.js";

  const container = document.getElementById("voxel-cat");

  if (container) {
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    const scene = new THREE.Scene();
    const model = new THREE.Group();
    scene.add(model);

    // ---- theme-reactive palette (mirrors the logo: white cat on dark, black cat on light) ----
    const THEMES = {
      // dark-mode whites toned down a touch so the belly doesn't glare / hides its texture
      dark: { fur: 0xe9e2d5, sock: 0xeee7d9, eye: 0x2b2b2b, whisker: 0xc9c3b6 },
      light: { fur: 0x2e2c31, sock: 0xf5f3ee, eye: 0xf5f3ee, whisker: 0x55525a },
    };
    const PINK = 0xe89aa4;
    const PINK_DARK = 0xd9808c;
    const TEAL = 0x0d9488;
    const TEAL_LIGHT = 0x14b8a6;
    const SCREEN_BG = 0xdff5f0;
    const SILVER = 0x40454d; // laptop body — graphite (was bright silver, glared in dark mode)
    const SILVER_DARK = 0x2b2f36; // keyboard / darker laptop parts
    // ---- desk props (developer vignette) ----
    const MUG = 0xe0785f; // warm terracotta-coral ceramic
    const COFFEE = 0x3f2a1d;
    const LEAF = 0x5a9a49;
    const LEAF_DARK = 0x437637;
    const POT = 0xb96a43;
    const SOIL = 0x2f2620;
    const BOOK_A = 0xc75d5d;
    const BOOK_B = 0xd7a13f;
    const BOOK_C = 0x3f6fa3;

    // ---- subtle fur "texture for color": faint grayscale mottle that multiplies
    // the theme color, so the pelt reads as crafted material instead of dead-flat. ----
    function makeFurTexture() {
      const s = 128;
      const c = document.createElement("canvas");
      c.width = c.height = s;
      const ctx = c.getContext("2d")!;
      ctx.fillStyle = "#ffffff";
      ctx.fillRect(0, 0, s, s);
      for (let i = 0; i < 900; i++) {
        const v = 232 + Math.floor(Math.random() * 22); // subtle darker specks
        ctx.fillStyle = `rgba(${v},${v},${v},0.45)`;
        ctx.beginPath();
        ctx.arc(Math.random() * s, Math.random() * s, 0.6 + Math.random() * 2.4, 0, Math.PI * 2);
        ctx.fill();
      }
      const tex = new THREE.CanvasTexture(c);
      tex.wrapS = tex.wrapT = THREE.RepeatWrapping;
      tex.colorSpace = THREE.SRGBColorSpace;
      tex.anisotropy = 4;
      return tex;
    }
    const furTex = makeFurTexture();

    // PBR materials — soft matte plastic/clay look, lit mostly by an environment map
    const matFur = new THREE.MeshStandardMaterial({ roughness: 0.96, metalness: 0.0, map: furTex, envMapIntensity: 0.28 });
    const matSock = new THREE.MeshStandardMaterial({ roughness: 0.92, metalness: 0.0, envMapIntensity: 0.22 });
    const matEye = new THREE.MeshStandardMaterial({ roughness: 0.32, metalness: 0.0, envMapIntensity: 0.9 });
    const matWhisker = new THREE.MeshStandardMaterial({ roughness: 0.6, metalness: 0.0, envMapIntensity: 0.4 });

    let ready = false; // renderer/camera exist — safe to render on demand
    function applyTheme() {
      const t = document.documentElement.classList.contains("dark") ? THEMES.dark : THEMES.light;
      matFur.color.set(t.fur);
      matSock.color.set(t.sock);
      matEye.color.set(t.eye);
      matWhisker.color.set(t.whisker);
      if (reduceMotion && ready) render();
    }
    applyTheme();
    new MutationObserver(applyTheme).observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["class"],
    });

    // Box from min-corner + size (voxel-style, everything axis-aligned)
    function B(
      parent: THREE.Object3D,
      x: number, y: number, z: number,
      w: number, h: number, d: number,
      material: THREE.Material | number
    ) {
      const mat =
        typeof material === "number"
          ? new THREE.MeshStandardMaterial({ color: material, roughness: 0.62, metalness: 0.0, envMapIntensity: 0.6 })
          : material;
      const mesh = new THREE.Mesh(new THREE.BoxGeometry(w, h, d), mat);
      mesh.position.set(x + w / 2, y + h / 2, z + d / 2);
      mesh.castShadow = true;
      mesh.receiveShadow = true;
      parent.add(mesh);
      return mesh;
    }

    // ---- teal rug (brand accent) ----
    const rug = new THREE.Mesh(
      new THREE.CylinderGeometry(7.4, 7.4, 0.35, 10),
      new THREE.MeshStandardMaterial({ color: TEAL, roughness: 0.85, metalness: 0.0, flatShading: true, envMapIntensity: 0.5 })
    );
    rug.position.y = 0.175;
    rug.receiveShadow = true;
    model.add(rug);
    const rugTop = new THREE.Mesh(
      new THREE.CylinderGeometry(5.9, 5.9, 0.12, 10),
      new THREE.MeshStandardMaterial({ color: TEAL_LIGHT, roughness: 0.8, metalness: 0.0, flatShading: true, envMapIntensity: 0.5 })
    );
    rugTop.position.y = 0.41;
    rugTop.receiveShadow = true;
    model.add(rugTop);

    const R = 0.45; // rug surface height — cat sits on top of it

    // body group (breathes)
    const body = new THREE.Group();
    body.position.y = R;
    model.add(body);

    // ---- sitting body built from small voxels (cat facing +z) ----
    // A smooth curved profile (superellipse cross-section that tapers with height)
    // is sampled on a fine grid, then only the visible shell cubes are kept and
    // merged — so the back/shoulders read as many small stepped blocks, not slabs.
    {
      const V = 0.45; // voxel size — small = thinner, finer layers (craftz-like)
      const P = 2.55; // superellipse exponent (rounded-rectangle cross-section)
      // profile control points: [y, halfWidthX, zBack, zFront]
      const PROFILE: [number, number, number, number][] = [
        [0.2, 2.5, -2.3, 1.7],
        [1.5, 3.0, -2.6, 1.9],
        [3.0, 2.85, -2.5, 1.85],
        [4.4, 2.55, -2.3, 1.6],
        [5.8, 2.3, -2.05, 1.45],
        [7.0, 2.0, -1.7, 1.2],
        [7.6, 1.8, -1.45, 1.05],
      ];
      const profileAt = (y: number) => {
        const yc = Math.max(PROFILE[0][0], Math.min(PROFILE[PROFILE.length - 1][0], y));
        let a = PROFILE[0], b = PROFILE[PROFILE.length - 1];
        for (let i = 0; i < PROFILE.length - 1; i++) {
          if (yc >= PROFILE[i][0] && yc <= PROFILE[i + 1][0]) { a = PROFILE[i]; b = PROFILE[i + 1]; break; }
        }
        const span = b[0] - a[0] || 1;
        let t = (yc - a[0]) / span;
        t = t * t * (3 - 2 * t); // smoothstep
        return {
          halfW: a[1] + (b[1] - a[1]) * t,
          zBack: a[2] + (b[2] - a[2]) * t,
          zFront: a[3] + (b[3] - a[3]) * t,
        };
      };

      const occ = new Set<string>();
      const cells: { ix: number; iy: number; iz: number; x: number; y: number; z: number }[] = [];
      const iyMax = Math.floor(7.55 / V);
      for (let iy = 0; iy <= iyMax; iy++) {
        const y = (iy + 0.5) * V;
        const pr = profileAt(y);
        const zc = (pr.zBack + pr.zFront) / 2;
        const zh = (pr.zFront - pr.zBack) / 2;
        const ixMax = Math.ceil(pr.halfW / V) + 1;
        const izMin = Math.floor(pr.zBack / V) - 1;
        const izMax = Math.ceil(pr.zFront / V) + 1;
        for (let ix = -ixMax; ix <= ixMax; ix++) {
          const x = ix * V;
          for (let iz = izMin; iz <= izMax; iz++) {
            const z = iz * V;
            const nx = Math.abs(x) / pr.halfW;
            const nz = Math.abs(z - zc) / zh;
            if (Math.pow(nx, P) + Math.pow(nz, P) <= 1) {
              occ.add(`${ix},${iy},${iz}`);
              cells.push({ ix, iy, iz, x, y, z });
            }
          }
        }
      }

      const has = (i: number, j: number, k: number) => occ.has(`${i},${j},${k}`);
      const furGeos: THREE.BufferGeometry[] = [];
      const sockGeos: THREE.BufferGeometry[] = [];
      // Cubes are slightly larger than the grid spacing so neighbours overlap —
      // no visible gaps ("cement") between them and no z-fighting on shared faces.
      const cube = () => new THREE.BoxGeometry(V * 1.06, V * 1.06, V * 1.06);
      for (const c of cells) {
        const { ix, iy, iz, x, y, z } = c;
        // keep the body SOLID (fill interior too) so you can never see through it;
        // surface cubes get the material of the face they expose.
        const g = cube();
        g.translate(x, y, z);
        // front-facing chest cubes in the bib window become the white patch
        const frontExposed = !has(ix, iy, iz + 1);
        const isBib = frontExposed && Math.abs(x) < 1.25 && y > 2.5 && y < 6.1;
        (isBib ? sockGeos : furGeos).push(g);
      }
      const furMesh = new THREE.Mesh(mergeGeometries(furGeos), matFur);
      furMesh.castShadow = true;
      furMesh.receiveShadow = true;
      body.add(furMesh);
      if (sockGeos.length) {
        const sockMesh = new THREE.Mesh(mergeGeometries(sockGeos), matSock);
        sockMesh.castShadow = true;
        sockMesh.receiveShadow = true;
        body.add(sockMesh);
      }
    }

    // ---- head (tilted slightly toward the raised paw) ----
    const head = new THREE.Group();
    head.position.set(-0.3, 7.6, 0);
    head.rotation.z = 0.07;
    head.rotation.x = 0.08; // looking down at the raised paw
    body.add(head);
    B(head, -2.3, 0, -1.4, 4.6, 3.4, 3.3, matFur); // skull (single box — Olivio prefers the square head)
    B(head, -1.05, 0.35, 1.9, 2.1, 1.05, 0.55, matSock); // muzzle
    B(head, -0.34, 1.12, 2.28, 0.68, 0.42, 0.3, PINK_DARK); // nose
    // happy closed eyes — slit + tiny outer step (˘ ˘)
    B(head, -1.85, 1.95, 2.12, 0.95, 0.2, 0.1, matEye);
    B(head, -1.98, 2.08, 2.12, 0.3, 0.2, 0.1, matEye);
    B(head, 0.9, 1.95, 2.12, 0.95, 0.2, 0.1, matEye);
    B(head, 1.68, 2.08, 2.12, 0.3, 0.2, 0.1, matEye);
    // whiskers
    B(head, -3.6, 0.55, 1.7, 1.7, 0.09, 0.09, matWhisker);
    B(head, -3.75, 0.95, 1.7, 1.85, 0.09, 0.09, matWhisker);
    B(head, 1.9, 0.55, 1.7, 1.7, 0.09, 0.09, matWhisker);
    B(head, 1.9, 0.95, 1.7, 1.85, 0.09, 0.09, matWhisker);
    // ears (refs kept for the twitch animation)
    const earL = B(head, -2.1, 3.4, -0.9, 1.25, 1.35, 1.0, matFur);
    const earR = B(head, 0.85, 3.4, -0.9, 1.25, 1.35, 1.0, matFur);
    B(head, -1.83, 3.4, 0.11, 0.7, 0.75, 0.12, PINK); // inner ears
    B(head, 1.12, 3.4, 0.11, 0.7, 0.75, 0.12, PINK);

    // ---- raised paw in front of the chin (like the logo), toe beans facing out ----
    B(body, -2.35, 5.2, 1.6, 1.25, 2.6, 1.25, matFur); // forearm up, forward of the chest
    B(body, -2.55, 7.6, 1.4, 1.6, 1.6, 1.65, matFur); // paw under the muzzle
    B(body, -2.45, 8.45, 3.03, 1.4, 0.62, 0.14, matSock); // pad backing
    B(body, -2.18, 7.92, 3.05, 0.86, 0.52, 0.18, PINK); // big bean
    B(body, -2.38, 8.55, 3.09, 0.34, 0.34, 0.18, PINK); // small beans
    B(body, -1.92, 8.62, 3.09, 0.34, 0.34, 0.18, PINK);
    B(body, -1.48, 8.52, 3.09, 0.34, 0.34, 0.18, PINK);

    // ---- other front leg, forward of the chest so it reads clearly ----
    B(body, 1.0, 1, 0.9, 1.35, 4.6, 1.35, matFur);
    B(body, 0.9, 0, 0.95, 1.6, 1.05, 2.2, matSock); // front foot
    B(body, -2.7, 0, 0.8, 1.5, 1.05, 2.2, matSock); // hind foot peeking

    // ---- tail: resting on the floor, curling around the cat's right side (sways) ----
    const tail = new THREE.Group();
    tail.position.set(2.6, R, -1.6); // pivot at the hip
    model.add(tail);
    const T = matFur;
    B(tail, -0.15, 0, -0.65, 0.9, 0.9, 0.9, T); // touches the hip
    B(tail, 0.6, 0, -0.1, 0.9, 0.9, 0.9, T); // swings out along the floor
    B(tail, 1.15, 0, 0.7, 0.9, 0.9, 0.9, T);
    B(tail, 1.3, 0, 1.6, 0.9, 0.9, 0.9, T); // curves forward
    B(tail, 1.0, 0, 2.4, 0.9, 0.9, 0.9, T); // curls back inward
    B(tail, 0.55, 0, 2.95, 0.8, 0.8, 0.8, matSock); // white tip resting on the floor

    // ---- open laptop on the floor in front of the cat ----
    const laptop = new THREE.Group();
    laptop.position.set(0.15, R, 3.8);
    laptop.rotation.y = -0.12; // slight angle so it reads as a laptop
    model.add(laptop);
    B(laptop, -1.9, 0, 0, 3.8, 0.3, 2.4, SILVER); // base
    B(laptop, -1.6, 0.3, 0.2, 3.2, 0.1, 1.6, SILVER_DARK); // keyboard
    B(laptop, -0.6, 0.31, 1.9, 1.2, 0.09, 0.4, SILVER_DARK); // touchpad
    const lid = new THREE.Group();
    lid.position.set(0, 0.15, 2.35); // hinge at the back edge
    lid.rotation.x = 0.18; // nearly upright, screen facing the cat
    laptop.add(lid);
    B(lid, -1.9, 0, -0.13, 3.8, 2.9, 0.26, SILVER); // lid
    B(lid, -1.6, 0.28, -0.24, 3.2, 2.35, 0.13, SCREEN_BG); // display
    // "code" lines on the display
    B(lid, -1.35, 2.0, -0.3, 1.7, 0.24, 0.06, TEAL);
    B(lid, -1.35, 1.55, -0.3, 1.0, 0.24, 0.06, PINK_DARK);
    B(lid, -0.9, 1.1, -0.3, 1.8, 0.24, 0.06, TEAL);
    // ---- "</>" developer logo on the lid back, bold blocky strokes ----
    const matIcon = new THREE.MeshStandardMaterial({ color: TEAL_LIGHT, roughness: 0.45, metalness: 0.0, envMapIntensity: 0.7 });
    const ICZ = 0.11; // just proud of the lid's back face
    const ISW = 0.16; // stroke thickness
    function stroke(x0: number, y0: number, x1: number, y1: number) {
      const steps = Math.max(2, Math.round(Math.hypot(x1 - x0, y1 - y0) / (ISW * 0.6)));
      for (let i = 0; i <= steps; i++) {
        const t = i / steps;
        const x = x0 + (x1 - x0) * t, y = y0 + (y1 - y0) * t;
        B(lid, x - ISW / 2, y - ISW / 2, ICZ, ISW, ISW, 0.05, matIcon);
      }
    }
    // left chevron "<"
    stroke(-0.42, 1.72, -0.74, 1.35);
    stroke(-0.74, 1.35, -0.42, 0.98);
    // center slash "/"
    stroke(-0.14, 0.94, 0.14, 1.76);
    // right chevron ">"
    stroke(0.42, 1.72, 0.74, 1.35);
    stroke(0.74, 1.35, 0.42, 0.98);

    // ---- coffee mug (front-left of the cat) with rising steam ----
    const mug = new THREE.Group();
    mug.position.set(-3.9, R, 3.7);
    mug.rotation.y = 0.6;
    model.add(mug);
    // DoubleSide so the inner wall of the open cup is visible (reads as hollow)
    const matMug = new THREE.MeshStandardMaterial({ color: MUG, roughness: 0.68, metalness: 0.0, flatShading: true, envMapIntensity: 0.4, side: THREE.DoubleSide });
    const matCoffee = new THREE.MeshStandardMaterial({ color: COFFEE, roughness: 0.4, metalness: 0.0, flatShading: true, envMapIntensity: 0.55 });
    // tapered faceted cup wall — OPEN top (no cap) so you can see into it
    const cupBody = new THREE.Mesh(new THREE.CylinderGeometry(0.62, 0.5, 1.15, 12, 1, true), matMug);
    cupBody.position.y = 0.575;
    cupBody.castShadow = true;
    cupBody.receiveShadow = true;
    mug.add(cupBody);
    // closed bottom
    const cupBottom = new THREE.Mesh(new THREE.CylinderGeometry(0.5, 0.5, 0.08, 12), matMug);
    cupBottom.position.y = 0.06;
    cupBottom.receiveShadow = true;
    mug.add(cupBottom);
    // coffee surface, recessed ~0.25 below the rim so there's a visible cavity
    const coffee = new THREE.Mesh(new THREE.CylinderGeometry(0.55, 0.55, 0.06, 12), matCoffee);
    coffee.position.y = 0.9;
    coffee.receiveShadow = true;
    mug.add(coffee);
    // ring handle — inner half hidden in the wall, outer half is the grip
    const handle = new THREE.Mesh(new THREE.TorusGeometry(0.27, 0.09, 8, 16), matMug);
    handle.position.set(0.6, 0.6, 0);
    handle.castShadow = true;
    mug.add(handle);

    const matSteam = () =>
      new THREE.MeshStandardMaterial({ color: 0xffffff, transparent: true, opacity: 0.4, roughness: 1, metalness: 0, depthWrite: false });
    const steamPuffs: { mesh: THREE.Mesh; baseY: number }[] = [];
    for (let i = 0; i < 3; i++) {
      const m = new THREE.Mesh(new THREE.BoxGeometry(0.26, 0.26, 0.26), matSteam());
      m.position.set(-3.85 + (i - 1) * 0.12, R + 1.2 + i * 0.28, 3.7);
      m.castShadow = false;
      model.add(m);
      steamPuffs.push({ mesh: m, baseY: m.position.y });
    }

    // ---- succulent in a terracotta pot (cat's left side) ----
    const plant = new THREE.Group();
    plant.position.set(-4.9, R, -0.6);
    model.add(plant);
    B(plant, -0.6, 0, -0.6, 1.2, 0.95, 1.2, POT); // pot
    B(plant, -0.5, 0.95, -0.5, 1.0, 0.16, 1.0, SOIL); // soil
    B(plant, -0.18, 1.05, -0.18, 0.36, 0.72, 0.36, LEAF); // center leaf
    B(plant, -0.56, 1.05, -0.14, 0.32, 0.55, 0.3, LEAF_DARK);
    B(plant, 0.24, 1.05, -0.14, 0.32, 0.55, 0.3, LEAF_DARK);
    B(plant, -0.14, 1.05, -0.56, 0.3, 0.5, 0.32, LEAF);
    B(plant, -0.14, 1.05, 0.26, 0.3, 0.5, 0.32, LEAF);

    // ---- stack of books (front-right, clear of the tail) ----
    const books = new THREE.Group();
    books.position.set(4.5, R, 3.3);
    books.rotation.y = -0.5;
    model.add(books);
    B(books, -0.9, 0, -0.7, 1.8, 0.34, 1.4, BOOK_C); // bottom
    B(books, -0.82, 0.34, -0.6, 1.66, 0.3, 1.28, BOOK_A); // middle
    B(books, -0.72, 0.64, -0.66, 1.5, 0.28, 1.32, BOOK_B); // top

    // center the model on x/z so it spins around its middle
    const bounds = new THREE.Box3().setFromObject(model);
    const center = bounds.getCenter(new THREE.Vector3());
    model.position.x = -center.x;
    model.position.z = -center.z;

    // ---- ground shadow ----
    const ground = new THREE.Mesh(
      new THREE.CircleGeometry(12, 48),
      new THREE.ShadowMaterial({ opacity: 0.16 })
    );
    ground.rotation.x = -Math.PI / 2;
    ground.receiveShadow = true;
    scene.add(ground);

    // ---- lights ----
    scene.add(new THREE.AmbientLight(0xffffff, 0.3));
    scene.add(new THREE.HemisphereLight(0xffffff, 0x8899aa, 0.35));
    const sun = new THREE.DirectionalLight(0xffffff, 1.2);
    sun.position.set(12, 20, 8);
    sun.castShadow = true;
    sun.shadow.mapSize.set(1024, 1024);
    sun.shadow.camera.left = -16;
    sun.shadow.camera.right = 16;
    sun.shadow.camera.top = 16;
    sun.shadow.camera.bottom = -16;
    scene.add(sun);

    // ---- camera (orthographic, orbiting) ----
    const target = new THREE.Vector3(0, 4.9, 0);
    const camera = new THREE.OrthographicCamera();
    const RADIUS = 30;
    const CAM_HEIGHT = 16; // slightly higher / more top-down view

    function frameCamera() {
      const aspect = container.clientWidth / Math.max(container.clientHeight, 1);
      let halfH = 8.4; // tall enough that the ears never clip while orbiting
      if (halfH * aspect < 8.5) halfH = 8.5 / aspect; // keep full width on narrow screens
      camera.left = -halfH * aspect;
      camera.right = halfH * aspect;
      camera.top = halfH;
      camera.bottom = -halfH;
      camera.near = 0.1;
      camera.far = 100;
      camera.updateProjectionMatrix();
    }

    const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.shadowMap.enabled = true;
    renderer.shadowMap.type = THREE.PCFSoftShadowMap;
    renderer.toneMapping = THREE.NeutralToneMapping; // gentle, hue-preserving product look
    renderer.toneMappingExposure = 0.98;
    container.appendChild(renderer.domElement);

    // soft studio environment (image-based lighting) — gives the matte-plastic sheen
    const pmrem = new THREE.PMREMGenerator(renderer);
    scene.environment = pmrem.fromScene(new RoomEnvironment(), 0.04).texture;
    pmrem.dispose();

    function resize() {
      renderer.setSize(container.clientWidth, container.clientHeight);
      frameCamera();
      // setSize clears the canvas; without the animation loop nothing redraws it
      if (reduceMotion && ready) render();
    }
    resize();
    new ResizeObserver(resize).observe(container);

    // ---- orbit controls: drag to rotate (X + Y), wheel/pinch to zoom ----
    const START = -0.35; // 3/4 view: face + raised paw toward the viewer
    camera.position.set(RADIUS * Math.sin(START), CAM_HEIGHT, RADIUS * Math.cos(START));
    camera.lookAt(target);

    const controls = new OrbitControls(camera, renderer.domElement);
    controls.target.copy(target);
    controls.enablePan = false;
    controls.enableDamping = !reduceMotion;
    controls.dampingFactor = 0.09;
    controls.rotateSpeed = 0.85;
    controls.zoomSpeed = 0.9;
    controls.minZoom = 0.65; // limit zoom-out
    controls.maxZoom = 2.6; // limit zoom-in
    controls.minPolarAngle = 0.55; // don't tip fully top-down
    controls.maxPolarAngle = 1.5; // don't dip under the floor
    controls.autoRotate = !reduceMotion; // always-on idle spin (never stops)
    controls.autoRotateSpeed = 1.8;
    controls.update();

    function render() {
      renderer.render(scene, camera);
    }
    if (reduceMotion) controls.addEventListener("change", render);

    // ---- idle life: breathing, tail sway, random ear twitch ----
    let twitchEar: THREE.Mesh | null = null;
    let twitchUntil = 0;
    let nextTwitch = performance.now() + 2500;

    function animateLife(now: number) {
      const s = now / 1000;
      body.scale.y = 1 + 0.012 * Math.sin(s * 1.7); // breathing
      tail.rotation.y = 0.10 * Math.sin(s * 1.2); // tail sway
      // coffee steam: each puff rises and fades on an offset loop
      steamPuffs.forEach((p, i) => {
        const ph = (s * 0.5 + i * 0.34) % 1;
        p.mesh.position.y = p.baseY + ph * 1.5;
        (p.mesh.material as THREE.MeshStandardMaterial).opacity = 0.42 * (1 - ph);
        const sc = 0.55 + ph * 0.7;
        p.mesh.scale.set(sc, sc, sc);
      });
      if (now > nextTwitch && !twitchEar) {
        twitchEar = Math.random() < 0.5 ? earL : earR;
        twitchUntil = now + 320;
      }
      if (twitchEar) {
        if (now < twitchUntil) {
          twitchEar.rotation.z = 0.3 * Math.sin(((twitchUntil - now) / 320) * Math.PI * 2);
        } else {
          twitchEar.rotation.z = 0;
          twitchEar = null;
          nextTwitch = now + 2500 + Math.random() * 4000;
        }
      }
    }

    // entrance: quick ease-out spin that settles into the idle rotation
    const ENTER_MS = 900;
    const startTime = performance.now();
    let visible = true;

    const io = new IntersectionObserver(([entry]) => {
      visible = entry.isIntersecting;
    });
    io.observe(container);

    function tick(now: number) {
      if (visible) {
        if (controls.autoRotate) {
          const t = Math.min((now - startTime) / ENTER_MS, 1);
          const easeOut = 1 - Math.pow(1 - t, 3);
          controls.autoRotateSpeed = 1.8 + 7 * (1 - easeOut); // fast → idle
        }
        controls.update(); // required for damping + auto-rotate
        animateLife(now);
        render();
      }
      requestAnimationFrame(tick);
    }

    ready = true;
    render();
    container.classList.add("is-ready");
    if (!reduceMotion) {
      requestAnimationFrame(tick);
    }
  }
</script>
