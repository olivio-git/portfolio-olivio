---
import type { Lang } from "../i18n/utils";
import { languages } from "../i18n/utils";

interface Props {
  lang: Lang;
  t: any;
}

const { lang, t } = Astro.props;
const otherLang = lang === "es" ? "en" : "es";

const currentPath = Astro.url.pathname;
const pathWithoutLang = currentPath.replace(/^\/(es|en)/, "") || "/";
const alternatePath = `/${otherLang}${pathWithoutLang === "/" ? "" : pathWithoutLang}`;
---

<!-- Desktop + Mobile header -->
<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <nav class="max-w-xl mx-auto flex items-center justify-between px-6 h-14">

    <!-- Logo -->
    <a
      href={`/${lang}`}
      class="flex items-center gap-2 text-base text-slate-900 dark:text-slate-100 hover:text-[#DA7756] transition-colors"
      style="font-family: 'M PLUS Rounded 1c', sans-serif; font-weight: 700;"
    >
      <img src="/cat_removed_background.png" alt="cat" class="w-7 h-7 object-contain dark:invert" />
      Olivio Subelza
    </a>

    <!-- Nav links — desktop only -->
    <ul class="hidden md:flex items-center gap-8 text-sm text-slate-500 dark:text-slate-400">
      <li>
        <a href={`/${lang}#work`} data-section="work"
           class="nav-link relative py-1 hover:text-slate-900 dark:hover:text-slate-100 transition-colors">
          {t.nav.work}
        </a>
      </li>
      <li>
        <a href={`/${lang}#services`} data-section="services"
           class="nav-link relative py-1 hover:text-slate-900 dark:hover:text-slate-100 transition-colors">
          {t.nav.services}
        </a>
      </li>
      <li>
        <a href={`/${lang}#contact`} data-section="contact"
           class="nav-link relative py-1 hover:text-slate-900 dark:hover:text-slate-100 transition-colors">
          {t.nav.contact}
        </a>
      </li>
    </ul>

    <!-- Controls (desktop) -->
    <div class="hidden md:flex items-center gap-3">
      <a
        href={alternatePath}
        class="text-xs font-medium px-2.5 py-1 rounded-lg
               text-slate-500 dark:text-slate-400
               hover:text-[#DA7756] transition-colors"
      >
        {languages[otherLang]}
      </a>
      <button
        id="theme-toggle"
        aria-label="Toggle theme"
        class="p-2 rounded-lg text-slate-500 dark:text-slate-400
               hover:text-[#DA7756] transition-colors"
      >
        <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden dark:block">
          <circle cx="12" cy="12" r="4"/>
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
        </svg>
        <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="block dark:hidden">
          <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
        </svg>
      </button>
    </div>

    <!-- Hamburger — mobile only -->
    <button
      id="menu-toggle"
      aria-label="Toggle menu"
      class="md:hidden p-2 text-slate-500 dark:text-slate-400 hover:text-[#DA7756] transition-colors"
    >
      <svg id="icon-menu" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="4" x2="20" y1="6" y2="6"/>
        <line x1="4" x2="20" y1="12" y2="12"/>
        <line x1="4" x2="20" y1="18" y2="18"/>
      </svg>
      <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden">
        <path d="M18 6 6 18M6 6l12 12"/>
      </svg>
    </button>
  </nav>

  <!-- Mobile menu panel -->
  <div
    id="mobile-menu"
    class="md:!hidden bg-white/95 dark:bg-[#1a1a1a]/95 backdrop-blur-xl"
  >
    <div class="max-w-xl mx-auto px-6 py-4 flex flex-col gap-1">
      <a href={`/${lang}#work`} data-mobile-link
         class="py-3 text-sm text-slate-600 dark:text-slate-300 hover:text-[#DA7756] transition-colors border-b border-slate-100 dark:border-slate-800/50">
        {t.nav.work}
      </a>
      <a href={`/${lang}#services`} data-mobile-link
         class="py-3 text-sm text-slate-600 dark:text-slate-300 hover:text-[#DA7756] transition-colors border-b border-slate-100 dark:border-slate-800/50">
        {t.nav.services}
      </a>
      <a href={`/${lang}#contact`} data-mobile-link
         class="py-3 text-sm text-slate-600 dark:text-slate-300 hover:text-[#DA7756] transition-colors border-b border-slate-100 dark:border-slate-800/50">
        {t.nav.contact}
      </a>
      <!-- Mobile controls row -->
      <div class="flex items-center gap-4 pt-3">
        <a
          href={alternatePath}
          class="text-xs font-medium px-3 py-1.5 rounded-lg
                 bg-slate-100 dark:bg-slate-800
                 text-slate-500 dark:text-slate-400
                 hover:text-[#DA7756] transition-colors"
        >
          {languages[otherLang]}
        </a>
        <button
          id="theme-toggle-mobile"
          aria-label="Toggle theme"
          class="flex items-center gap-2 text-sm text-slate-500 dark:text-slate-400 hover:text-[#DA7756] transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden dark:block">
            <circle cx="12" cy="12" r="4"/>
            <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
          </svg>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="block dark:hidden">
            <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
          </svg>
          <span class="dark:hidden">Dark</span>
          <span class="hidden dark:inline">Light</span>
        </button>
      </div>
    </div>
  </div>
</header>

<style is:global>
  .nav-link {
    display: inline-block;
  }
  .nav-link::after {
    content: "";
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 100%;
    height: 1.5px;
    background-color: #DA7756;
    transform: scaleX(0);
    transition: transform 0.25s ease, opacity 0.25s ease;
    transform-origin: left;
    opacity: 0.6;
  }
  .nav-link:hover::after,
  .nav-link.active::after {
    transform: scaleX(1);
  }
  .nav-link.active {
    color: #DA7756;
  }
  .nav-link.active::after {
    opacity: 1;
  }

  /* Mobile menu slide animation */
  #mobile-menu {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.25s ease;
    overflow: hidden;
  }
  #mobile-menu.open {
    grid-template-rows: 1fr;
  }
  #mobile-menu > div {
    overflow: hidden;
  }
</style>

<script is:inline>
  // Active section via scroll
  const navLinks = document.querySelectorAll(".nav-link[data-section]");
  const sections = ["work", "services", "contact"];

  function setActive(id) {
    navLinks.forEach((link) => link.classList.remove("active"));
    const active = document.querySelector('.nav-link[data-section="' + id + '"]');
    if (active) active.classList.add("active");
  }

  function onScroll() {
    let current = "";
    sections.forEach((id) => {
      const el = document.getElementById(id);
      if (el && el.getBoundingClientRect().top <= window.innerHeight * 0.4) {
        current = id;
      }
    });
    if (current) setActive(current);
    else navLinks.forEach((link) => link.classList.remove("active"));
  }

  window.addEventListener("scroll", onScroll, { passive: true });

  // Scroll-triggered header blur — inline styles to avoid Tailwind purge
  const header = document.getElementById("site-header");
  function updateHeader() {
    if (window.scrollY > 20) {
      header.style.backgroundColor = "rgba(255,255,255,0.8)";
      header.style.backdropFilter = "blur(20px)";
      header.style.webkitBackdropFilter = "blur(20px)";
    } else {
      header.style.backgroundColor = "";
      header.style.backdropFilter = "";
      header.style.webkitBackdropFilter = "";
    }
  }

  // Respect dark mode for header bg
  function updateHeaderColor() {
    if (window.scrollY > 20) {
      const isDark = document.documentElement.classList.contains("dark");
      header.style.backgroundColor = isDark ? "rgba(26,26,26,0.85)" : "rgba(255,255,255,0.8)";
    }
  }

  window.addEventListener("scroll", () => { updateHeader(); updateHeaderColor(); }, { passive: true });
  updateHeader();

  // Theme toggle (desktop + mobile)
  function toggleTheme() {
    const isDark = document.documentElement.classList.toggle("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
    updateHeaderColor();
  }
  document.getElementById("theme-toggle")?.addEventListener("click", toggleTheme);
  document.getElementById("theme-toggle-mobile")?.addEventListener("click", toggleTheme);

  // Mobile menu
  const menuToggle = document.getElementById("menu-toggle");
  const mobileMenu = document.getElementById("mobile-menu");
  const iconMenu = document.getElementById("icon-menu");
  const iconClose = document.getElementById("icon-close");

  menuToggle?.addEventListener("click", () => {
    const isOpen = mobileMenu.classList.contains("open");
    mobileMenu.classList.toggle("open", !isOpen);
    iconMenu.classList.toggle("hidden", !isOpen);
    iconClose.classList.toggle("hidden", isOpen);
  });

  // Close mobile menu when a link is clicked
  document.querySelectorAll("[data-mobile-link]").forEach((link) => {
    link.addEventListener("click", () => {
      mobileMenu.classList.remove("open");
      iconMenu.classList.remove("hidden");
      iconClose.classList.add("hidden");
    });
  });
</script>
