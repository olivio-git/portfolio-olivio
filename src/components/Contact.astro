---
import type { Lang } from "../i18n/utils";

interface Props {
  lang: Lang;
  t: any;
}
const { lang, t } = Astro.props;

const FORMSPREE_ID = "xdaywoqy";
---

<section id="contact" class="px-6 py-16 md:py-24 border-t border-slate-100 dark:border-slate-800/50">
  <div class="max-w-xl mx-auto">

    <p class="text-[#DA7756] text-sm font-medium tracking-wider uppercase mb-6">Contact</p>

    <h2 class="text-2xl md:text-3xl font-semibold text-slate-900 dark:text-slate-50 mb-3"
        style="font-family: 'M PLUS Rounded 1c', sans-serif;">
      {t.contact.title}
    </h2>
    <p class="text-slate-400 dark:text-slate-500 text-sm mb-10">
      {t.contact.sub}
    </p>

    <!-- Form -->
    <form
      id="contact-form"
      action={`https://formspree.io/f/${FORMSPREE_ID}`}
      method="POST"
      class="flex flex-col gap-4 mb-10"
    >
      <div class="grid sm:grid-cols-2 gap-4">
        <div class="flex flex-col gap-1.5">
          <label for="name" class="text-xs font-medium text-slate-500 dark:text-slate-400">
            {t.contact.form.name}
          </label>
          <input
            id="name"
            type="text"
            name="name"
            required
            class="px-4 py-2.5 rounded-xl text-sm
                   bg-slate-50 dark:bg-slate-800/60
                   border border-slate-200 dark:border-slate-700
                   text-slate-900 dark:text-slate-100
                   placeholder:text-slate-300 dark:placeholder:text-slate-600
                   focus:outline-none focus:border-[#DA7756] dark:focus:border-[#DA7756]
                   transition-colors"
          />
        </div>
        <div class="flex flex-col gap-1.5">
          <label for="email" class="text-xs font-medium text-slate-500 dark:text-slate-400">
            {t.contact.form.email}
          </label>
          <input
            id="email"
            type="email"
            name="email"
            required
            class="px-4 py-2.5 rounded-xl text-sm
                   bg-slate-50 dark:bg-slate-800/60
                   border border-slate-200 dark:border-slate-700
                   text-slate-900 dark:text-slate-100
                   placeholder:text-slate-300 dark:placeholder:text-slate-600
                   focus:outline-none focus:border-[#DA7756] dark:focus:border-[#DA7756]
                   transition-colors"
          />
        </div>
      </div>

      <div class="flex flex-col gap-1.5">
        <label for="message" class="text-xs font-medium text-slate-500 dark:text-slate-400">
          {t.contact.form.message}
        </label>
        <textarea
          id="message"
          name="message"
          required
          rows="5"
          placeholder={t.contact.form.message_placeholder}
          class="px-4 py-2.5 rounded-xl text-sm resize-none
                 bg-slate-50 dark:bg-slate-800/60
                 border border-slate-200 dark:border-slate-700
                 text-slate-900 dark:text-slate-100
                 placeholder:text-slate-300 dark:placeholder:text-slate-600
                 focus:outline-none focus:border-[#DA7756] dark:focus:border-[#DA7756]
                 transition-colors"
        />
      </div>

      <div class="flex items-center gap-4">
        <button
          type="submit"
          id="submit-btn"
          class="px-6 py-2.5 rounded-xl text-sm font-medium
                 bg-slate-900 dark:bg-slate-100
                 text-white dark:text-slate-900
                 hover:opacity-90 transition-opacity
                 disabled:opacity-50 disabled:cursor-not-allowed"
        >
          {t.contact.form.send}
        </button>

        <p id="form-status" class="text-sm hidden"></p>
      </div>
    </form>

    <!-- Email con copy -->
    <div class="flex items-center gap-2 mb-8
                px-4 py-2.5 rounded-xl w-fit
                bg-slate-50 dark:bg-slate-800/60
                border border-slate-200 dark:border-slate-700">
      <span class="text-sm text-slate-500 dark:text-slate-400 select-all">
        subelzaolivitocabezas@gmail.com
      </span>
      <button
        id="copy-email-btn"
        aria-label="Copiar email"
        class="ml-1 p-1 rounded-lg text-slate-400 dark:text-slate-500
               hover:text-[#DA7756] transition-colors"
      >
        <svg id="icon-copy" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect width="14" height="14" x="8" y="8" rx="2" ry="2"/>
          <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>
        </svg>
        <svg id="icon-check" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="hidden text-emerald-500">
          <path d="M20 6 9 17l-5-5"/>
        </svg>
      </button>
    </div>

    <!-- Social -->
    <div class="flex items-center gap-6">
      <a href="https://github.com/olivio-git" target="_blank" rel="noopener noreferrer"
         class="text-sm text-slate-400 dark:text-slate-500 hover:text-slate-800 dark:hover:text-slate-200
                transition-colors underline-offset-4 hover:underline">
        GitHub
      </a>
      <a href="https://www.linkedin.com/in/olivio-subelza-cabezas-b646a2249" target="_blank" rel="noopener noreferrer"
         class="text-sm text-slate-400 dark:text-slate-500 hover:text-slate-800 dark:hover:text-slate-200
                transition-colors underline-offset-4 hover:underline">
        LinkedIn
      </a>
    </div>

  </div>
</section>

<script define:vars={{ successMsg: t.contact.form.success, errorMsg: t.contact.form.error, sendingMsg: t.contact.form.sending, sendMsg: t.contact.form.send }}>
  const form = document.getElementById("contact-form");
  const btn = document.getElementById("submit-btn");
  const status = document.getElementById("form-status");

  const copyBtn = document.getElementById("copy-email-btn");
  const iconCopy = document.getElementById("icon-copy");
  const iconCheck = document.getElementById("icon-check");

  copyBtn?.addEventListener("click", () => {
    navigator.clipboard.writeText("subelzaolivitocabezas@gmail.com").then(() => {
      iconCopy.classList.add("hidden");
      iconCheck.classList.remove("hidden");
      setTimeout(() => {
        iconCopy.classList.remove("hidden");
        iconCheck.classList.add("hidden");
      }, 2000);
    });
  });

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    btn.disabled = true;
    btn.textContent = sendingMsg;
    status.classList.add("hidden");

    try {
      const res = await fetch(form.action, {
        method: "POST",
        body: new FormData(form),
        headers: { Accept: "application/json" },
      });

      if (res.ok) {
        form.reset();
        status.textContent = successMsg;
        status.className = "text-sm text-emerald-500";
        btn.textContent = sendMsg;
        btn.disabled = false;
      } else {
        throw new Error();
      }
    } catch {
      status.textContent = errorMsg;
      status.className = "text-sm text-red-400";
      btn.textContent = sendMsg;
      btn.disabled = false;
    }
  });
</script>
