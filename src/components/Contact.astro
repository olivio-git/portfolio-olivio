---
import type { Lang } from "../i18n/utils";

interface Props {
  lang: Lang;
  t: any;
}
const { lang, t } = Astro.props;
---

<section id="contact" class="px-6 py-16 md:py-24 border-t border-slate-100 dark:border-slate-800/50">
  <div class="max-w-xl mx-auto">

    <p class="text-[#DA7756] text-sm font-medium tracking-wider uppercase mb-6">Contact</p>

    <h2 class="text-2xl md:text-3xl font-semibold text-slate-900 dark:text-slate-50 mb-3"
        style="font-family: 'M PLUS Rounded 1c', sans-serif;">
      {t.contact.title}
    </h2>
    <p class="text-slate-400 dark:text-slate-500 text-sm mb-12">
      {t.contact.sub}
    </p>

    <!-- Email grande -->
    <a
      href="mailto:subelzaolivitocabezas@gmail.com"
      class="group block mb-12"
    >
      <span class="text-xl md:text-2xl font-semibold text-slate-800 dark:text-slate-100
                   underline decoration-slate-200 dark:decoration-slate-700 underline-offset-4
                   decoration-2 group-hover:decoration-[#DA7756] group-hover:text-[#DA7756]
                   transition-all duration-200"
            style="font-family: 'M PLUS Rounded 1c', sans-serif; font-weight: 300;">
        subelzaolivitocabezas@gmail.com
      </span>
      <span class="inline-block ml-2 text-slate-300 dark:text-slate-600
                   group-hover:text-[#DA7756] group-hover:translate-x-1
                   transition-all duration-200 text-lg">
        →
      </span>
    </a>

    <!-- Social -->
    <div class="flex items-center gap-6">
      <a href="https://github.com/olivio-git" target="_blank" rel="noopener noreferrer"
         class="text-sm text-slate-400 dark:text-slate-500 hover:text-slate-800 dark:hover:text-slate-200
                transition-colors underline-offset-4 hover:underline">
        GitHub
      </a>
      <a href="https://www.linkedin.com/in/olivio-subelza-cabezas-b646a2249" target="_blank" rel="noopener noreferrer"
         class="text-sm text-slate-400 dark:text-slate-500 hover:text-slate-800 dark:hover:text-slate-200
                transition-colors underline-offset-4 hover:underline">
        LinkedIn
      </a>
    </div>

  </div>
</section>
