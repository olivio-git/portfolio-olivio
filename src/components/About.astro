---
interface Props {
  t: any;
}
const { t } = Astro.props;
---

<section id="about" class="px-6 py-8">
  <div class="reveal max-w-lg mx-auto">
    <h2 class="section-title text-xl font-bold text-stone-900 dark:text-slate-50 mb-4">
      {t.about.title}
    </h2>
    <div class="space-y-3">
      {t.about.bio.map((paragraph: string, idx: number) => (
        <p class:list={["text-sm text-stone-700 dark:text-slate-400 leading-relaxed text-justify", idx === 0 && "indent-8"]}>
          {paragraph.split(/\*(.+?)\*/g).map((part, i) =>
            i % 2 === 1 ? <span class="hl">{part}</span> : part
          )}
        </p>
      ))}
    </div>

    <!-- Timeline (craftz "Bio"-style year rows) -->
    <div class="mt-8">
      <h3 class="section-title text-xl font-bold text-stone-900 dark:text-slate-50 mb-4">
        {t.about.timeline_label}
      </h3>
      <div class="space-y-1.5">
        {t.about.timeline.map((item: { year: string; text: string }) => (
          <div class="flex gap-4">
            <span
              class="shrink-0 w-12 font-bold text-sm leading-relaxed text-[#0D9488]"
              style="font-family: 'M PLUS Rounded 1c', sans-serif;"
            >
              {item.year}
            </span>
            <p class="text-sm text-stone-700 dark:text-slate-400 leading-relaxed">
              {item.text}
            </p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
