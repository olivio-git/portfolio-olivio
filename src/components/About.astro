---
interface Props {
  t: any;
}
const { t } = Astro.props;
---

<section id="about" class="px-6 py-16 md:py-24 border-t border-slate-100 dark:border-slate-800/50">
  <div class="max-w-xl mx-auto">
    <div class="mb-10">
      <p class="text-[#DA7756] text-sm font-medium tracking-wider uppercase mb-3">
        {t.about.label}
      </p>
      <h2 class="text-2xl md:text-3xl font-semibold text-slate-900 dark:text-slate-50 mb-6">
        {t.about.title}
      </h2>
    </div>
    <div class="space-y-4">
      {t.about.bio.map((paragraph: string) => (
        <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">
          {paragraph}
        </p>
      ))}
    </div>
  </div>
</section>
