---
import type { Lang } from "../i18n/utils";

interface Props {
  lang: Lang;
  t: any;
}

const { lang, t } = Astro.props;
---

<section class="px-6 pt-28 pb-16">
  <div class="max-w-xl mx-auto w-full">

    <!-- Name + photo row -->
    <div class="flex items-center justify-between gap-4 mb-3">
      <div>
        <h1
          class="text-2xl font-bold text-slate-900 dark:text-slate-50 mb-1"
          style="font-family: 'M PLUS Rounded 1c', sans-serif;"
        >
          {t.hero.name}
        </h1>
        <p class="text-sm text-slate-500 dark:text-slate-400">
          {t.hero.role}
        </p>
      </div>

      <!-- Avatar — replace /photo.jpg with your actual photo -->
      <div class="shrink-0">
        <img
          src="/photo.jpg"
          alt={t.hero.name}
          class="w-24 h-24 rounded-full object-cover ring-2 ring-slate-200 dark:ring-slate-700 ring-offset-2 ring-offset-white dark:ring-offset-[#1a1a1a]"
          onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
        />
        <!-- Fallback initials (hidden when photo loads) -->
        <div
          class="w-24 h-24 rounded-full bg-slate-100 dark:bg-slate-800 ring-2 ring-slate-200 dark:ring-slate-700 ring-offset-2 ring-offset-white dark:ring-offset-[#1a1a1a]
                 items-center justify-center text-base font-semibold text-slate-500 dark:text-slate-400 hidden"
          aria-hidden="true"
        >
          OS
        </div>
      </div>
    </div>

    <!-- Bio -->
    <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed mb-8 max-w-md">
      {t.hero.bio}
    </p>

    <!-- Compact CTAs -->
    <div class="flex flex-wrap items-center gap-2">
      <a
        href={`#work`}
        class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg
               bg-[#DA7756] hover:bg-[#e8896e] text-white font-medium
               transition-colors text-sm"
      >
        {t.hero.cta_work}
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m6 9 6 6 6-6"/>
        </svg>
      </a>
      <a
        href={`#contact`}
        class="inline-flex items-center px-4 py-2 rounded-lg
               border border-slate-200 dark:border-slate-700
               text-slate-700 dark:text-slate-300 font-medium
               hover:border-[#DA7756] hover:text-[#DA7756]
               transition-colors text-sm"
      >
        {t.hero.cta_contact}
      </a>
      <a
        href="/CV_OLIVIO.pdf"
        download
        class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg
               border border-slate-200 dark:border-slate-700
               text-slate-700 dark:text-slate-300 font-medium
               hover:border-[#DA7756] hover:text-[#DA7756]
               transition-colors text-sm"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/>
        </svg>
        {t.hero.cta_cv}
      </a>
    </div>

  </div>
</section>
