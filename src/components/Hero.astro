---
import type { Lang } from "../i18n/utils";
import VoxelCat from "./VoxelCat.astro";

interface Props {
  lang: Lang;
  t: any;
}

const { lang, t } = Astro.props;
---

<section class="px-6 pt-20 pb-10">
  <div class="reveal max-w-lg mx-auto w-full">

    <!-- 3D voxel cat (craftz-style, drag to spin) -->
    <VoxelCat />

    <!-- Greeting box (glassy, craftz-style) -->
    <div
      class="mb-6 rounded-lg px-4 py-2.5 text-center text-sm text-stone-700 dark:text-slate-300
             bg-slate-900/5 dark:bg-white/8 backdrop-blur-md"
    >
      {t.hero.greeting}
    </div>

    <!-- Name + photo row -->
    <div class="flex items-center justify-between gap-4 mb-6">
      <div>
        <h1
          class="text-3xl md:text-4xl font-bold text-stone-900 dark:text-slate-50 mb-1.5 tracking-tight"
          style="font-family: 'M PLUS Rounded 1c', sans-serif;"
        >
          {t.hero.name}
        </h1>
        <p class="text-sm md:text-base text-stone-600 dark:text-slate-400">
          {t.hero.role}
        </p>
      </div>

      <!-- Avatar — replace /photo.jpg with your actual photo -->
      <div class="shrink-0">
        <img
          src="/photo.jpg"
          alt={t.hero.name}
          class="w-20 h-20 rounded-full object-cover ring-2 ring-stone-300 dark:ring-slate-700 ring-offset-2 ring-offset-[#F0E7DB] dark:ring-offset-[#1B1A18]"
          onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
        />
        <!-- Fallback initials (hidden when photo loads) -->
        <div
          class="w-20 h-20 rounded-full bg-stone-100 dark:bg-slate-800 ring-2 ring-stone-300 dark:ring-slate-700 ring-offset-2 ring-offset-[#F0E7DB] dark:ring-offset-[#1B1A18]
                 items-center justify-center text-base font-semibold text-stone-600 dark:text-slate-400 hidden"
          aria-hidden="true"
        >
          OS
        </div>
      </div>
    </div>

    <!-- Compact CTAs -->
    <div class="flex flex-wrap items-center gap-2">
      <a
        href={`#work`}
        class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg
               bg-[#0D9488] hover:bg-[#14B8A6] text-white font-medium
               transition-colors text-sm"
      >
        {t.hero.cta_work}
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m6 9 6 6 6-6"/>
        </svg>
      </a>
      <a
        href={`#contact`}
        class="inline-flex items-center px-4 py-2 rounded-lg
               border border-stone-300 dark:border-slate-700
               text-stone-700 dark:text-slate-300 font-medium
               hover:border-[#0D9488] hover:text-[#0D9488]
               transition-colors text-sm"
      >
        {t.hero.cta_contact}
      </a>
      <a
        href="/CV_OLIVIO.pdf"
        download
        class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg
               border border-stone-300 dark:border-slate-700
               text-stone-700 dark:text-slate-300 font-medium
               hover:border-[#0D9488] hover:text-[#0D9488]
               transition-colors text-sm"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/>
        </svg>
        {t.hero.cta_cv}
      </a>
    </div>

  </div>
</section>
