---
interface Props {
  t: any;
}
const { t } = Astro.props;
---

<section id="services" class="px-6 py-8">
  <div class="reveal max-w-lg mx-auto">
    <h2 class="section-title text-xl font-bold text-stone-900 dark:text-slate-50 mb-1.5">
      {t.services.title}
    </h2>
    <p class="text-stone-600 dark:text-slate-400 text-sm mb-4">
      {t.services.sub}
    </p>

    <!-- Numbered list -->
    <div>
      {t.services.items.map((item: any, i: number) => (
        <div class="flex gap-5 py-3">
          <span class="text-xs font-mono text-stone-400 dark:text-slate-600 pt-0.5 w-5 shrink-0 select-none">
            0{i + 1}
          </span>
          <div>
            <h3 class="text-sm font-semibold text-stone-900 dark:text-slate-50 mb-1">
              {item.title}
            </h3>
            <p class="text-sm text-stone-600 dark:text-slate-400 leading-relaxed">
              {item.desc}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
