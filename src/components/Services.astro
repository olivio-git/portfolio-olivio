---
interface Props {
  t: any;
}
const { t } = Astro.props;
---

<section id="services" class="px-6 py-16 md:py-24 border-t border-slate-100 dark:border-slate-800/50">
  <div class="max-w-xl mx-auto">
    <!-- Header -->
    <div class="mb-10">
      <p class="text-[#DA7756] text-sm font-medium tracking-wider uppercase mb-3">
        Services
      </p>
      <h2 class="text-2xl md:text-3xl font-semibold text-slate-900 dark:text-slate-50 mb-3">
        {t.services.title}
      </h2>
      <p class="text-slate-500 dark:text-slate-400 text-sm">
        {t.services.sub}
      </p>
    </div>

    <!-- Numbered list -->
    <div>
      {t.services.items.map((item: any, i: number) => (
        <div class="flex gap-5 py-6 border-b border-slate-100 dark:border-slate-800/50">
          <span class="text-xs font-mono text-slate-300 dark:text-slate-600 pt-0.5 w-5 shrink-0 select-none">
            0{i + 1}
          </span>
          <div>
            <h3 class="text-sm font-semibold text-slate-900 dark:text-slate-50 mb-1.5">
              {item.title}
            </h3>
            <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed">
              {item.desc}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
