---
interface Props {
  t: any;
}
const { t } = Astro.props;

const icons = [
  // Rocket
  `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg>`,
  // Server
  `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="8" x="2" y="2" rx="2" ry="2"/><rect width="20" height="8" x="2" y="14" rx="2" ry="2"/><line x1="6" x2="6.01" y1="6" y2="6"/><line x1="6" x2="6.01" y1="18" y2="18"/></svg>`,
  // Monitor
  `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="3" rx="2"/><line x1="8" x2="16" y1="21" y2="21"/><line x1="12" x2="12" y1="17" y2="21"/></svg>`,
  // Search code
  `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m13 13.5 2-2.5-2-2.5"/><path d="m21 21-4.35-4.35"/><path d="M9 10.5 7 13l2 2.5"/><circle cx="11" cy="11" r="8"/></svg>`,
];
---

<section id="services" class="px-6 py-24 md:py-32">
  <div class="max-w-xl mx-auto">
    <!-- Header -->
    <div class="mb-16">
      <p class="text-[#DA7756] text-sm font-medium tracking-wider uppercase mb-3">
        {/* Services label */}
        Services
      </p>
      <h2 class="text-2xl md:text-3xl font-semibold text-slate-900 dark:text-slate-50 mb-4">
        {t.services.title}
      </h2>
      <p class="text-slate-500 dark:text-slate-400 text-sm max-w-xl">
        {t.services.sub}
      </p>
    </div>

    <!-- Grid -->
    <div class="grid sm:grid-cols-2 gap-px bg-slate-100 dark:bg-slate-800/50 rounded-2xl overflow-hidden border border-slate-100 dark:border-slate-800/50">
      {t.services.items.map((item: any, i: number) => (
        <div class="bg-white dark:bg-[#1a1a1a] p-8 hover:bg-slate-50 dark:hover:bg-slate-900/30 transition-colors">
          <div class="w-10 h-10 rounded-xl bg-[#DA7756]/10 flex items-center justify-center text-[#DA7756] mb-5"
               set:html={icons[i]} />
          <h3 class="font-semibold text-slate-900 dark:text-slate-50 mb-2">{item.title}</h3>
          <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
