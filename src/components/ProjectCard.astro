---
import type { CollectionEntry } from "astro:content";
import type { Lang } from "../i18n/utils";
import { useTranslations } from "../i18n/utils";

interface Props {
  project: CollectionEntry<"projects">;
  lang: Lang;
  index: number;
}

const { project, lang } = Astro.props;
const t = useTranslations(lang);
const { title, description, description_en, image, type, year } = project.data;
const desc = lang === "en" ? description_en : description;
const slug = project.id;
---

<article class="group">
  <a href={`/${lang}/projects/${slug}`} class="block">

    <!-- Image — full width, large -->
    <div class="w-full overflow-hidden rounded-xl mb-4
                bg-slate-100 dark:bg-slate-800/50">
      {image ? (
        <img
          src={image}
          alt={title}
          class="w-full object-cover object-top
                 group-hover:scale-[1.02] transition-transform duration-500 ease-out"
          loading="lazy"
        />
      ) : (
        <div class="aspect-video flex items-center justify-center bg-slate-100 dark:bg-slate-800/80">
          <span class="text-4xl font-bold text-slate-200 dark:text-slate-700"
                style="font-family: 'M PLUS Rounded 1c', sans-serif;">
            {title.charAt(0)}
          </span>
        </div>
      )}
    </div>

    <!-- Text — minimal -->
    <div class="flex items-start justify-between gap-4">
      <div>
        <h3 class="text-sm font-semibold text-slate-900 dark:text-slate-100
                   group-hover:text-[#DA7756] transition-colors">
          {title}
        </h3>
        <p class="text-xs text-slate-400 dark:text-slate-500 mt-0.5 leading-relaxed line-clamp-2">
          {desc}
        </p>
      </div>
      <span class="text-xs text-slate-300 dark:text-slate-600 flex-shrink-0 mt-0.5">{year}</span>
    </div>

  </a>
</article>
