---
interface Props {
  t: any;
}
const { t } = Astro.props;

const techGroups = [
  {
    key: "frontend" as const,
    items: ["TypeScript", "React", "Tauri", "Next.js", "Astro", "Tailwind CSS", "HTML/CSS"],
  },
  {
    key: "backend" as const,
    items: ["Node.js", "Express", "PostgreSQL", "MongoDB", "Prisma", "REST APIs", "GraphQL", "Rust"],
  },
  {
    key: "mobile" as const,
    items: ["React Native", "Expo"],
  },
  {
    key: "devops" as const,
    items: ["Git", "GitHub Actions", "Docker", "Vercel", "Linux"],
  },
];
---

<section id="stack" class="px-6 py-16 md:py-24 border-t border-slate-100 dark:border-slate-800/50">
  <div class="max-w-xl mx-auto">
    <div class="mb-10">
      <p class="text-[#DA7756] text-sm font-medium tracking-wider uppercase mb-3">{t.tech.label}</p>
      <h2 class="text-2xl md:text-3xl font-semibold text-slate-900 dark:text-slate-50 mb-3">{t.tech.title}</h2>
      <p class="text-slate-500 dark:text-slate-400 text-sm">{t.tech.sub}</p>
    </div>

    <div class="space-y-6">
      {techGroups.map((group) => (
        <div>
          <h3 class="text-xs font-medium text-slate-400 dark:text-slate-500 uppercase tracking-wider mb-2.5">
            {t.tech.categories[group.key]}
          </h3>
          <div class="flex flex-wrap gap-1.5">
            {group.items.map((tech) => (
              <span class="px-2.5 py-1 text-xs rounded-md bg-slate-50 dark:bg-slate-800/80 text-slate-600 dark:text-slate-400 border border-slate-200 dark:border-slate-700/80">
                {tech}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
