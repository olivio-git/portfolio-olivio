---
interface Props {
  t: any;
}
const { t } = Astro.props;

const techGroups = [
  {
    key: "frontend" as const,
    items: ["TypeScript", "React", "Tauri", "Next.js", "Astro", "Tailwind CSS", "HTML/CSS"],
  },
  {
    key: "backend" as const,
    items: ["Node.js", "Express", "PostgreSQL", "MongoDB", "Prisma", "REST APIs", "GraphQL", "Rust"],
  },
  {
    key: "mobile" as const,
    items: ["React Native", "Expo"],
  },
  {
    key: "devops" as const,
    items: ["Git", "GitHub Actions", "Docker", "Vercel", "Linux"],
  },
];
---

<section id="stack" class="px-6 py-8">
  <div class="reveal max-w-lg mx-auto">
    <h2 class="section-title text-xl font-bold text-stone-900 dark:text-slate-50 mb-1.5">{t.tech.title}</h2>
    <p class="text-stone-600 dark:text-slate-400 text-sm mb-4">{t.tech.sub}</p>

    <div class="space-y-4">
      {techGroups.map((group) => (
        <div>
          <h3 class="text-xs font-medium text-stone-500 dark:text-slate-500 uppercase tracking-wider mb-2.5">
            {t.tech.categories[group.key]}
          </h3>
          <div class="flex flex-wrap gap-1.5">
            {group.items.map((tech) => (
              <span class="px-2.5 py-1 text-xs rounded-md bg-stone-50 dark:bg-slate-800/80 text-stone-700 dark:text-slate-400 border border-stone-300 dark:border-slate-700/80">
                {tech}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
