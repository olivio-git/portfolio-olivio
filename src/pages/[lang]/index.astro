---
import Layout from "../../layouts/Layout.astro";
import Hero from "../../components/Hero.astro";
import About from "../../components/About.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import Services from "../../components/Services.astro";
import TechStack from "../../components/TechStack.astro";
import Contact from "../../components/Contact.astro";
import { useTranslations, type Lang } from "../../i18n/utils";
import { getCollection } from "astro:content";

export function getStaticPaths() {
  return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);

const seoTitle =
  lang === "es"
    ? "Olivio Subelza — Desarrollador Full-Stack"
    : "Olivio Subelza — Full-Stack Developer";
const seoDescription =
  lang === "es"
    ? "Olivio Subelza — Desarrollador Full-Stack de Bolivia. Construyo productos digitales con React, Node.js y React Native. Disponible para freelance y oportunidades laborales."
    : "Olivio Subelza — Full-Stack Developer from Bolivia. I build digital products with React, Node.js, and React Native. Available for freelance and job opportunities.";

const allProjects = await getCollection("projects");
const featuredProjects = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);
---

<Layout lang={lang} t={t} title={seoTitle} description={seoDescription}>
  <Hero lang={lang} t={t} />
  <About t={t} />

  <!-- Projects section -->
  <section id="work" class="px-6 py-8">
    <div class="reveal max-w-lg mx-auto">
      <h2 class="section-title text-xl font-bold text-stone-900 dark:text-slate-50 mb-5">
        {t.projects.title}
      </h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-8">
        {featuredProjects.map((project, i) => (
          <ProjectCard project={project} lang={lang} index={i} />
        ))}
      </div>
    </div>
  </section>

  <Services t={t} />
  <TechStack t={t} />
  <Contact lang={lang} t={t} />
</Layout>
