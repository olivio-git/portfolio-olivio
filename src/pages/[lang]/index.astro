---
import Layout from "../../layouts/Layout.astro";
import Hero from "../../components/Hero.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import Services from "../../components/Services.astro";
import Contact from "../../components/Contact.astro";
import { useTranslations, type Lang } from "../../i18n/utils";
import { getCollection } from "astro:content";

export function getStaticPaths() {
  return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);

const allProjects = await getCollection("projects");
const featuredProjects = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);
---

<Layout lang={lang} t={t}>
  <Hero lang={lang} t={t} />

  <!-- Projects section -->
  <section id="work" class="px-6 py-14 md:py-20 border-t border-slate-100 dark:border-slate-800/50">
    <div class="max-w-xl mx-auto">
      <div class="mb-4">
        <p class="text-[#DA7756] text-sm font-medium tracking-wider uppercase mb-3">Work</p>
        <h2 class="text-2xl md:text-3xl font-semibold text-slate-900 dark:text-slate-50">
          {t.projects.title}
        </h2>
      </div>

      <div class="mt-10 flex flex-col gap-10">
        <!-- Row 1 -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          {featuredProjects.slice(0, 2).map((project, i) => (
            <ProjectCard project={project} lang={lang} index={i} />
          ))}
        </div>
        <!-- Separador -->
        {featuredProjects.length > 2 && (
          <div class="border-t border-slate-100 dark:border-slate-800/50" />
        )}
        <!-- Row 2 -->
        {featuredProjects.length > 2 && (
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            {featuredProjects.slice(2).map((project, i) => (
              <ProjectCard project={project} lang={lang} index={i + 2} />
            ))}
          </div>
        )}
      </div>
    </div>
  </section>

  <Services t={t} />
  <Contact lang={lang} t={t} />
</Layout>
