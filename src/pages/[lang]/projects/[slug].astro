---
import Layout from "../../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";
import { useTranslations, type Lang } from "../../../i18n/utils";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  const langs: Lang[] = ["es", "en"];
  return langs.flatMap((lang) =>
    projects.map((project) => ({
      params: { lang, slug: project.id },
      props: { project },
    }))
  );
}

const { lang } = Astro.params as { lang: Lang };
const { project } = Astro.props;
const t = useTranslations(lang);
const { Content } = await render(project);
const { title, description, description_en, image, images, tech, github, demo, type, status, year } = project.data;
const desc = lang === "en" ? description_en : description;
---

<Layout lang={lang} title={`${title} — Olivio`} description={desc}>
  <article class="min-h-screen px-6 pt-32 pb-24">
    <div class="max-w-xl mx-auto">

      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 mb-12 text-sm font-medium">
        <a
          href={`/${lang}#work`}
          class="text-[#DA7756] hover:text-[#c46040] transition-colors"
        >
          {lang === "es" ? "Trabajos" : "Work"}
        </a>
        <span class="text-slate-300 dark:text-slate-600 select-none">›</span>
        <span class="text-slate-900 dark:text-slate-100 flex items-center gap-2">
          {title}
          <span class="text-xs font-medium px-2 py-0.5 rounded-full
                       bg-slate-100 dark:bg-slate-800
                       text-slate-400 dark:text-slate-500 leading-none">
            {year}
          </span>
        </span>
      </nav>

      <!-- Description -->
      <p class="text-lg font-medium text-slate-500 dark:text-slate-400 leading-relaxed mb-10 max-w-xl"
         style="font-family: 'M PLUS Rounded 1c', sans-serif;">
        {desc}
      </p>

      <!-- Links -->
      <div class="flex flex-wrap items-center gap-4 mb-16">
        {github && (
          <a href={github} target="_blank" rel="noopener noreferrer"
             class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl
                    bg-slate-900 dark:bg-slate-100 text-white dark:text-slate-900
                    text-sm font-medium hover:opacity-90 transition-opacity">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
            </svg>
            {t.projects.view_code}
          </a>
        )}
        {demo && (
          <a href={demo} target="_blank" rel="noopener noreferrer"
             class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl
                    border border-slate-200 dark:border-slate-700
                    text-slate-700 dark:text-slate-300 text-sm font-medium
                    hover:border-[#DA7756] hover:text-[#DA7756] transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6v6M10 14 21 3"/>
            </svg>
            {t.projects.view_demo}
          </a>
        )}
      </div>

      <!-- Hero image -->
      {image && (
        <div class="rounded-2xl overflow-hidden border border-slate-200 dark:border-slate-700/50 mb-16">
          <img src={image} alt={title} class="w-full" loading="eager" />
        </div>
      )}

      <!-- Tech stack -->
      <div class="mb-16">
        <p class="text-xs font-medium text-slate-400 dark:text-slate-500 uppercase tracking-wider mb-4">
          {lang === "es" ? "Tecnologías" : "Tech stack"}
        </p>
        <div class="flex flex-wrap gap-2">
          {tech.map((item) => (
            <span class="text-sm px-3 py-1.5 rounded-lg
                         border border-slate-200 dark:border-slate-700
                         text-slate-600 dark:text-slate-400 font-mono">
              {item}
            </span>
          ))}
        </div>
      </div>

      <!-- Content from md -->
      <div class="prose prose-slate dark:prose-invert max-w-none
                  prose-headings:font-semibold prose-a:text-[#DA7756]">
        <Content />
      </div>

      <!-- Additional images -->
      {images && images.length > 0 && (
        <div class="mt-16 grid sm:grid-cols-2 gap-4">
          {images.map((img) => (
            <div class="rounded-xl overflow-hidden border border-slate-200 dark:border-slate-700/50">
              <img src={img} alt={`${title} screenshot`} class="w-full" loading="lazy" />
            </div>
          ))}
        </div>
      )}

    </div>
  </article>
</Layout>
