---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import type { Lang } from "../i18n/utils";
import { useTranslations } from "../i18n/utils";

interface Props {
  title?: string;
  description?: string;
  lang?: Lang;
  ogImage?: string;
}

const {
  title = "Olivio Subelza — Full-Stack Developer",
  description = "Full-Stack Developer building digital products. Available for freelance.",
  lang = "es",
  ogImage,
} = Astro.props;

const t = useTranslations(lang);

const SITE = "https://oliviodev.com";
const canonical = `${SITE}${Astro.url.pathname}`;
const alternateLang: Lang = lang === "es" ? "en" : "es";
const alternatePath = Astro.url.pathname.replace(/^\/(es|en)/, `/${alternateLang}`);
const alternateHref = `${SITE}${alternatePath}`;
const ogImageUrl = ogImage ? `${SITE}${ogImage}` : `${SITE}/cat2.png`;

const personSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Olivio Subelza",
  url: SITE,
  jobTitle: "Full-Stack Developer",
  email: "subelzaolivitocabezas@gmail.com",
  sameAs: [
    "https://github.com/olivio-git",
    "https://www.linkedin.com/in/olivio-subelza-cabezas-b646a2249",
  ],
});
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Canonical & hreflang -->
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang={lang} href={canonical} />
    <link rel="alternate" hreflang={alternateLang} href={alternateHref} />
    <link rel="alternate" hreflang="x-default" href={`${SITE}/es`} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={lang === "es" ? "es_ES" : "en_US"} />
    <meta property="og:site_name" content="Olivio Subelza" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/cat2.png" />

    <!-- JSON-LD: Person schema -->
    <script type="application/ld+json" set:html={personSchema} />

    <!-- Theme init: prevent flash -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem("theme");
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        if (stored === "dark" || (!stored && prefersDark)) {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>
  </head>
  <body class="bg-white dark:bg-[#1a1a1a] text-slate-900 dark:text-slate-100 transition-colors duration-200">
    <Navbar lang={lang} t={t} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} t={t} />
  </body>
</html>
