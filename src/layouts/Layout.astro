---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import type { Lang } from "../i18n/utils";
import { useTranslations } from "../i18n/utils";

interface Props {
  title?: string;
  description?: string;
  lang?: Lang;
}

const {
  title = "Olivio Subelza — Full-Stack Developer",
  description = "Full-Stack Developer building digital products. Available for freelance.",
  lang = "es",
} = Astro.props;

const t = useTranslations(lang);
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <!-- Theme init: prevent flash -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem("theme");
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        if (stored === "dark" || (!stored && prefersDark)) {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>
  </head>
  <body class="bg-white dark:bg-[#1a1a1a] text-slate-900 dark:text-slate-100 transition-colors duration-200">
    <Navbar lang={lang} t={t} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} t={t} />
  </body>
</html>
